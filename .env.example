# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=assetflow
POSTGRES_PASSWORD=assetflow_secret
POSTGRES_DB=assetflow
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Assembled by the app — do not set manually; set the parts above.
# DATABASE_URL=postgresql://assetflow:assetflow_secret@db:5432/assetflow

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Password Reset ────────────────────────────────────────────────────────────
# Token TTL in minutes
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=AssetFlow
FRONTEND_URL=http://localhost:5173

# ── Email (SMTP for password reset) ──────────────────────────────────────────
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=noreply@assetflow.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ── Seed ──────────────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@assetflow.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123!
SUPER_ADMIN_FULL_NAME=Super Administrator
